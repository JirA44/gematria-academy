# Cloudflare Pages Headers Configuration
# Optimisation des performances et sécurité

# Configuration globale pour tous les fichiers
/*
  # Sécurité
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

  # Cache par défaut (1 heure)
  Cache-Control: public, max-age=3600, must-revalidate

# HTML - Cache court (5 minutes)
/*.html
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/html; charset=utf-8

# CSS - Cache long (1 an)
/*.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8

# JavaScript - Cache long (1 an)
/*.js
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/javascript; charset=utf-8

# Images - Cache très long (1 an)
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/jpeg

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/jpeg

/*.png
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/png

/*.svg
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/svg+xml

/*.webp
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/webp

# Fonts - Cache très long (1 an)
/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/woff

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/woff2

/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/ttf

# JSON - Cache court (1 heure)
/*.json
  Cache-Control: public, max-age=3600
  Content-Type: application/json; charset=utf-8

# Manifest PWA - Cache court
/manifest.json
  Cache-Control: public, max-age=3600
  Content-Type: application/manifest+json

# Service Worker - Pas de cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/javascript; charset=utf-8
